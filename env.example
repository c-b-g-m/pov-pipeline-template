# ─── Required ────────────────────────────────────────────────────────────────

# Claude API key (get one at https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Absolute path to your website's git repo (where content PRs will be created)
SITE_REPO_PATH=/path/to/your/website/repo

# ─── Optional ────────────────────────────────────────────────────────────────

# Brave Web Search API key — enables broader article discovery beyond RSS feeds
# Get one at https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Firecrawl API key — enables full article scraping for higher quality drafts
# Get one at https://firecrawl.dev/
FIRECRAWL_API_KEY=

# Buffer access token — used by the post-merge workflow in your SITE repo,
# not by the pipeline itself. See .github/workflows/buffer-on-merge.example.yml
# Get one at https://buffer.com/developers/
# BUFFER_ACCESS_TOKEN=
# BUFFER_ORGANIZATION_ID=

# ─── Tuning (defaults are fine for most users) ──────────────────────────────

# Max articles to process per run (default: 3)
MAX_CANDIDATES=3

# Seconds to wait between API calls (default: 2)
RATE_LIMIT_SLEEP=2
